<odoo>
    <record id="view_workorder_tree" model="ir.ui.view">
        <field name="name">workorder.tree</field>
        <field name="model">maintenance.workorder</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>             <field name="asset_id"/>         <field name="work_order_type"/>  <field name="technician_id"/>    <field name="status"/>           <field name="start_date"/>       <field name="end_date"/>         </tree>
        </field>
    </record>

    <record id="view_workorder_form" model="ir.ui.view">
        <field name="name">workorder.form</field>
        <field name="model">maintenance.workorder</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="asset_id" options="{'no_create': True}"/>
                        <field name="schedule_id"
                               domain="[('status','=','planned'), ('asset_id','=',asset_id)]"
                               context="{'default_asset_id': asset_id}"/>
                        <field name="work_order_type"/>
                        <field name="technician_id"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>

                    <notebook>
                        <page string="Technician Assignments">
                            <field name="assignment_ids">
                                <tree editable="bottom">
                                    <field name="technician_id"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
</odoo>